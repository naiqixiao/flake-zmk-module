        td_bs_word_line: tap_dance_backspace {
            compatible = "zmk,behavior-tap-dance";
            display-name = "Tap Dance";
            label = "TD_BS_WORD_LINE";
            #binding-cells = <0>;
            tapping-term-ms = <190>;    // Slightly longer to allow for 3 taps
            bindings =
                <&kp BACKSPACE>,
                <&kp LA(BACKSPACE)>,
                <&kp RG(BACKSPACE)>;

            // 3 Taps: Clear Line Macro
        };

        // 1. Press hml key.
        // 2. If a trigger key is pressed or released while held -> choose hold immediately.
        // 3. Else if released within 200 ms with no trigger activity -> tap.
        // 4. Else if 200 ms elapses with no trigger -> hold.
        // 5. Quick-tap may force tap on rapid repeats.
        // 6. prior idle time must be > 50ms at press to allow hold (prevent accidental holds while typing).
        // 7. hold-trigger-on-release: releasing a trigger key also forces hold (improves roll handling).

        hml: hml {
            compatible = "zmk,behavior-hold-tap";
            display-name = "Mod-Tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;        // optional tighter term so holds trigger sooner
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;  // allows faster hold triggering after idle
            bindings = <&kp>, <&kp>;

            hold-trigger-key-positions = <5 6 7 8 9 19 29 28 27 17 18 26 16 15 25 35 36 37>;        // force hold as soon as a right-hand key is released
            hold-trigger-on-release;
        };

        hmr: hmr {
            compatible = "zmk,behavior-hold-tap";
            display-name = "Mod-Tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;        // optional tighter term so holds trigger sooner
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;  // allows faster hold triggering after idle
            bindings = <&kp>, <&kp>;

            hold-trigger-key-positions = <0 1 2 3 4 10 11 12 13 14 20 21 22 23 24 33 34 32>;        // force hold as soon as a right-hand key is released
            hold-trigger-on-release;
        };

        hml_shift: hml_shift {
            compatible = "zmk,behavior-hold-tap";
            display-name = "Mod-Tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;
